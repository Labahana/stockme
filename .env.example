# App
NEXT_PUBLIC_APP_URL=https://stockme.gentletap.co
NEXT_PUBLIC_SHOPIFY_API_KEY=

# Shopify Partner app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_locations,read_orders
SHOPIFY_API_VERSION=2026-07
# Set to true during App Store review to use test charges on dev stores
SHOPIFY_BILLING_TEST=false
# Set to true on custom/development apps so billing API errors are bypassed in test mode
SHOPIFY_BILLING_CUSTOM_APP=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest (webhook queue + background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend (low-stock digests + PO emails to suppliers)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@stockme.gentletap.co

# Protect /api/cron/* (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Optional: local scripts for free-tier ops (never commit real values)
# SUPABASE_ACCESS_TOKEN=   # scripts/apply-migration-007.cjs
# VERCEL_TOKEN=            # scripts/push-cron-secret-vercel.cjs
# VERCEL_PROJECT_NAME=stocky
# VERCEL_TEAM_ID=
