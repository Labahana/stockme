# App
NEXT_PUBLIC_APP_URL=https://stockme.gentletap.co
NEXT_PUBLIC_SHOPIFY_API_KEY=

# Shopify Partner app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_locations,read_orders
SHOPIFY_API_VERSION=2026-07
# true = test charges (App Store review / non-prod). false = live merchant charges.
# If unset: test outside Vercel production, live in production.
SHOPIFY_BILLING_TEST=true
# Set to true only for custom/development apps that cannot use the Billing API
SHOPIFY_BILLING_CUSTOM_APP=false
# Demo: billing is also hard-disabled in code via BILLING_DISABLED_FOR_DEMO in src/lib/constants.ts
# Set that flag to false before App Store launch.
# Dev-only: allow ?shop= API auth without App Bridge session token
# STOCKME_ALLOW_QUERY_SHOP_AUTH=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest (webhook queue + background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend (low-stock digests + PO emails to suppliers)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@stockme.gentletap.co

# Protect /api/cron/* (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Optional: local scripts for free-tier ops (never commit real values)
# SUPABASE_ACCESS_TOKEN=   # scripts/apply-migration-007.cjs
# VERCEL_TOKEN=            # scripts/push-cron-secret-vercel.cjs
# VERCEL_PROJECT_NAME=stocky
# VERCEL_TEAM_ID=
